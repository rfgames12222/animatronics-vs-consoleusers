{
  "name": "animatronics-vs-console-user-multiplayer",
  "version": "1.0.0",
  "description": "Servidor multiplayer cooperativo (ate 5 guardas noturnos) para Animatronics vs Console User",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg . --targets node22-win-x64 --output dist/AnimatronicsServer.exe"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.0.0"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist"
  }
}
